# Required
ANTHROPIC_API_KEY=your_key_here

# Optional — API security (leave unset for local dev with no auth)
# API_KEY=your_stepwise_api_key
# CORS_ORIGINS=*

# Optional — data paths (defaults shown)
# DATA_DIR=./data
# DB_PATH=./data/stepwise.db
# CHROMA_PATH=./data/chroma
# FRAMES_DIR=./data/frames

# Optional — models and ingestion
# CLAUDE_MODEL=claude-sonnet-4-6
# STRUCTURING_MODEL=claude-haiku-4-5-20251001
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# FRAME_INTERVAL_SECONDS=5
# WATCHER_POLL_ENABLED=true
# WATCHER_POLL_INTERVAL_MINUTES=30

# When API_KEY is set, clients must send:  X-API-Key: <key>
# or Authorization: Bearer <key>.  /health and OpenAPI docs stay public.
# CORS_ORIGINS: comma-separated list (e.g. http://localhost:3000) or * for all.
