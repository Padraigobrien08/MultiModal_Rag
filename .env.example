# Required
ANTHROPIC_API_KEY=your_key_here

# Optional — API security (leave unset for local dev with no auth)
# When API_KEY is set on the API, set the same value on the web service so the BFF can forward it.
# API_KEY=your_stepwise_api_key
# CORS_ORIGINS=*

# Optional — data paths (defaults shown)
# DATA_DIR=./data
# DB_PATH=./data/stepwise.db
# CHROMA_PATH=./data/chroma
# FRAMES_DIR=./data/frames

# Optional — Claude models, one per pipeline stage (defaults shown).
# Model IDs change over time; check Anthropic's model docs before changing:
#   https://platform.claude.com/docs/en/about-claude/models/overview
# STRUCTURING_MODEL=claude-haiku-4-5-20251001   # step extraction (high volume)
# HYDE_MODEL=claude-haiku-4-5                    # HyDE hypothetical-answer generation
# SYNTHESIS_MODEL=claude-haiku-4-5              # streamed answer synthesis
# CONSOLIDATION_MODEL=claude-sonnet-4-6        # step consolidation (judgment)

# Optional — embeddings and ingestion
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# FRAME_INTERVAL_SECONDS=5
# WATCHER_POLL_ENABLED=true
# WATCHER_POLL_INTERVAL_MINUTES=30

# When API_KEY is set, clients must send:  X-API-Key: <key>
# or Authorization: Bearer <key>.  /health, /ready, and OpenAPI docs stay public.
# CORS_ORIGINS: comma-separated list (e.g. http://localhost:3000) or * for all.
